// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(cuid())
  name             String?
  email            String?        @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             String         @default("user")
  elo              Int            @default(1000)
  packsUnlocked    Json           @default("[]")
  history          Json           @default("[]")
  balance          Int            @default(0)
  creatorBadge     Boolean        @default(false)
  stripeCustomerId String?
  accounts         Account[]
  sessions         Session[]
  packsCreated     Pack[]         @relation("PackCreator")
  transactions     Transaction[]
  withdrawals      Withdrawal[]
  purchases        PackPurchase[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Pack {
  id              String         @id
  name            String
  theme           String         @default("training")
  subtitle        String?
  description     String?        @db.Text
  tier            Int            @default(1)
  difficulty      String         @default("intermediate")
  price           String         @default("Free")
  imageUrl        String?
  isPremium       Boolean        @default(false)
  tournament      String?
  creator         User?          @relation("PackCreator", fields: [creatorId], references: [id])
  creatorId       String?
  isCommunity     Boolean        @default(false)
  status          String         @default("approved")
  priceIP         Int?
  creatorShareIP  Int?
  rejectionReason String?
  submittedAt     DateTime?
  approvedAt      DateTime?
  scenarios       Scenario[]
  purchases       PackPurchase[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @default(now()) @updatedAt
}

model Scenario {
  id            String   @id
  packId        String
  pack          Pack     @relation(fields: [packId], references: [id], onDelete: Cascade)
  theme         String?
  subcategory   String?
  map           String   @default("Any")
  title         String
  description   String   @db.Text
  image         String?
  videoUrl      String?
  overlay       Json?
  macro         Json
  micro         Json
  communication Json
  options       Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  amountIP  Int
  status    String   @default("completed")
  stripeRef String?
  packId    String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Withdrawal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountIP      Int
  amountUSD     Float
  status        String    @default("pending")
  payoutMethod  String?
  payoutDetails Json?
  rejectionReason String?
  createdAt     DateTime  @default(now())
  paidAt        DateTime?

  @@index([userId, createdAt])
}

model PackPurchase {
  id        String   @id @default(cuid())
  userId    String
  packId    String
  amountIP  Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack      Pack     @relation(fields: [packId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, packId])
  @@index([packId])
}
