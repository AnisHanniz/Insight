// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user")
  elo           Int       @default(1000)
  packsUnlocked Json      @default("[]")
  history       Json      @default("[]")
  accounts      Account[]
  sessions      Session[]
  packsCreated  Pack[]    @relation("PackCreator")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Pack {
  id          String     @id
  name        String
  theme       String     @default("training")
  subtitle    String?
  description String?    @db.Text
  tier        Int        @default(1)
  difficulty  String     @default("intermediate")
  price       String     @default("Free")
  imageUrl    String?
  isPremium   Boolean    @default(false)
  tournament  String?
  creator     User?      @relation("PackCreator", fields: [creatorId], references: [id])
  creatorId   String?
  scenarios   Scenario[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt
}

model Scenario {
  id            String   @id
  packId        String
  pack          Pack     @relation(fields: [packId], references: [id], onDelete: Cascade)
  theme         String?
  subcategory   String?
  map           String   @default("Any")
  title         String
  description   String   @db.Text
  image         String?
  videoUrl      String?
  overlay       Json?
  macro         Json
  micro         Json
  communication Json
  options       Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}